@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix iiopm: <https://growgraph.dev/iiopm#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

iiopm:ARIMAModel a rdfs:Class ;
    rdfs:label "ARIMA Model" ;
    rdfs:comment "ARIMA forecasting model." ;
    rdfs:subClassOf iiopm:ForecastingModel,
        iiopm:PredictiveModel .

iiopm:Anomaly a rdfs:Class ;
    rdfs:label "Anomaly"^^xsd:string ;
    rdfs:comment "Abstract anomaly detected in time series data."^^xsd:string ;
    rdfs:subClassOf iiopm:QualityMetric .

iiopm:AnomalyDetectionModel a rdfs:Class ;
    rdfs:label "Anomaly Detection Model"^^xsd:string ;
    rdfs:comment "Model used to detect anomalies in time series data."^^xsd:string ;
    rdfs:subClassOf iiopm:PredictiveModel .

iiopm:AnomalyDetectionResult a rdfs:Class ;
    rdfs:label "Anomaly Detection Result"^^xsd:string ;
    rdfs:comment "Abstract result indicating presence of anomalies in data streams."^^xsd:string ;
    rdfs:subClassOf iiopm:QualityMetric .

iiopm:AnomalyEvent a rdfs:Class ;
    rdfs:label "Anomaly Event"^^xsd:string ;
    rdfs:comment "Abstract representation of detected anomalies in sensor data."^^xsd:string,
        "Event representing an occurrence of an anomaly in sensor data."^^xsd:string,
        "Observed abnormal pattern indicating potential degradation or fault."^^xsd:string ;
    rdfs:subClassOf iiopm:FailureEvent ;
    owl:sameAs iiopm:AnomalyDetectionModel,
        iiopm:AnomalyDetectionResult .

iiopm:DataQualityMetric a rdfs:Class ;
    rdfs:label "Data Quality Metric"^^xsd:string ;
    rdfs:comment "Metric characterizing the quality of sensor data (completeness, consistency, outliers)."^^xsd:string ;
    rdfs:subClassOf iiopm:QualityMetric .

iiopm:DataStream a rdfs:Class ;
    rdfs:label "Data Stream" ;
    rdfs:comment "Data emitted by sensors." .

iiopm:DataTransmission a rdfs:Class ;
    rdfs:label "Data Transmission" ;
    rdfs:comment "Data transmission process." .

iiopm:EdgeDataTransmission a rdfs:Class ;
    rdfs:label "Edge Data Transmission"^^xsd:string ;
    rdfs:comment "Data transmission from edge devices to gateway/IPC, often via local network."^^xsd:string ;
    rdfs:subClassOf iiopm:DataTransmission .

iiopm:FailureEvent a rdfs:Class ;
    rdfs:label "Failure Event" ;
    rdfs:comment "Abstract failure event." .

iiopm:Forecast a rdfs:Class ;
    rdfs:label "Forecast" ;
    rdfs:comment "Forecasted time series." ;
    rdfs:subClassOf iiopm:TimeSeries .

iiopm:ForecastErrorMetric a rdfs:Class ;
    rdfs:label "Forecast Error Metric"^^xsd:string ;
    rdfs:comment "Quality metric describing the accuracy of forecasts."^^xsd:string ;
    rdfs:subClassOf iiopm:QualityMetric .

iiopm:ForecastingModel a rdfs:Class ;
    rdfs:label "Forecasting Model"^^xsd:string ;
    rdfs:comment "Abstract class for models that forecast future values from historical data."^^xsd:string ;
    rdfs:subClassOf iiopm:PredictiveModel .

iiopm:IndustrialMachine a rdfs:Class ;
    rdfs:label "Industrial Machine" ;
    rdfs:comment "Abstract manufacturing machine with sensors." ;
    rdfs:subClassOf iiopm:PhysicalAsset .

iiopm:IoTProtocol a rdfs:Class ;
    rdfs:label "IoT Protocol" ;
    rdfs:comment "Protocol used for data transmission." .

iiopm:MQTTProtocol a rdfs:Class ;
    rdfs:label "MQTT Protocol"^^xsd:string ;
    rdfs:comment "MQTT is a lightweight publish/subscribe messaging protocol used in IIoT systems."^^xsd:string ;
    rdfs:subClassOf iiopm:IoTProtocol .

iiopm:MaintenanceAction a rdfs:Class ;
    rdfs:label "Maintenance Action" ;
    rdfs:comment "Abstract maintenance action." .

iiopm:MaintenanceRecommendation a rdfs:Class ;
    rdfs:label "Maintenance Recommendation"^^xsd:string ;
    rdfs:comment "Action recommended by predictive maintenance analysis."^^xsd:string ;
    rdfs:subClassOf iiopm:MaintenanceAction .

iiopm:Parameter a rdfs:Class ;
    rdfs:label "Parameter" ;
    rdfs:comment "Measured machine parameter." .

iiopm:PhysicalAsset a rdfs:Class ;
    rdfs:label "Physical Asset" ;
    rdfs:comment "Tangible industrial asset." ;
    rdfs:subClassOf schema1:Thing .

iiopm:PredictionWindow a rdfs:Class ;
    rdfs:label "Prediction Window"^^xsd:string ;
    rdfs:comment "Time window covered by a forecast."^^xsd:string ;
    rdfs:subClassOf iiopm:TimeSeries .

iiopm:PredictiveModel a rdfs:Class ;
    rdfs:label "Predictive Model" ;
    rdfs:comment "Model to forecast future values." .

iiopm:QualityMetric a rdfs:Class ;
    rdfs:label "Quality Metric" ;
    rdfs:comment "Abstract quality metric." .

iiopm:Sensor a rdfs:Class ;
    rdfs:label "Sensor" ;
    rdfs:comment "Measurement device." .

iiopm:SensorDataStream a rdfs:Class ;
    rdfs:label "Sensor Data Stream"^^xsd:string ;
    rdfs:comment "Time-series emitted directly by a specific sensor."^^xsd:string ;
    rdfs:subClassOf iiopm:DataStream .

iiopm:SensorNetworkTopology a rdfs:Class ;
    rdfs:label "Sensor Network Topology"^^xsd:string ;
    rdfs:comment "Abstract representation of sensor layout and communication topology."^^xsd:string ;
    rdfs:subClassOf skos:Concept .

iiopm:TimeSeries a rdfs:Class ;
    rdfs:label "Time Series" ;
    rdfs:comment "Time-indexed measurements." ;
    rdfs:subClassOf iiopm:DataStream .

iiopm:TimeWindow a rdfs:Class ;
    rdfs:label "Time Window"^^xsd:string ;
    rdfs:comment "Abstract representation of a time interval used for aggregations."^^xsd:string ;
    rdfs:subClassOf skos:Concept .

iiopm:Unit a rdfs:Class ;
    rdfs:label "Unit"^^xsd:string ;
    rdfs:comment "Measurement unit for parameter values."^^xsd:string ;
    rdfs:subClassOf schema1:Thing .

<https://growgraph.dev/iiopm> a owl:Ontology ;
    rdfs:label "Industrial IoT Predictive Maintenance Ontology" ;
    dcterms:created "2026-03-22T17:26:20.607270+00:00"^^xsd:dateTime ;
    dcterms:description "Domain ontology for IIoT-based predictive maintenance, modeling industrial machines, sensors, data streams, time-series, and ARIMA-based forecasting, with connections to standard vocabularies." ;
    dcterms:identifier "hash:b1f886724cf00addca6273cffa3400ae6473a4c9f421f2220cbb817d0a6c12d5" ;
    dcterms:title "iiopm" ;
    rdfs:comment "Domain ontology for IIoT-based predictive maintenance, modeling industrial machines, sensors, data streams, time-series, and ARIMA-based forecasting, with connections to standard vocabularies." ;
    owl:versionInfo "1.0.1" ;
    prov:wasDerivedFrom <urn:hash:28a1fec836436fcf201d6a9fd272d124bac73ec99735a8512a9934079580a295> .

iiopm:AnomalyScore a owl:DatatypeProperty ;
    rdfs:label "anomaly score"^^xsd:string ;
    rdfs:comment "Numeric score indicating severity of anomaly."^^xsd:string ;
    rdfs:domain iiopm:Anomaly ;
    rdfs:range xsd:double .

iiopm:forecastValue a owl:DatatypeProperty ;
    rdfs:label "forecast value" ;
    rdfs:comment "Numeric forecast value." ;
    rdfs:domain iiopm:Forecast ;
    rdfs:range xsd:double .

iiopm:hasAnomaly a owl:ObjectProperty ;
    rdfs:label "has anomaly"^^xsd:string ;
    rdfs:comment "Relates a TimeSeries to an Anomaly."^^xsd:string ;
    rdfs:domain iiopm:TimeSeries ;
    rdfs:range iiopm:Anomaly ;
    owl:sameAs iiopm:hasAnomalyEvent .

iiopm:hasDataStream a owl:ObjectProperty ;
    rdfs:label "has data stream"^^xsd:string ;
    rdfs:comment "Links a machine to the time-series data streams it generates."^^xsd:string ;
    rdfs:domain iiopm:IndustrialMachine ;
    rdfs:range iiopm:TimeSeries .

iiopm:hasForecastModel a owl:ObjectProperty ;
    rdfs:label "has forecast model" ;
    rdfs:comment "Links forecast to its model." ;
    rdfs:domain iiopm:Forecast ;
    rdfs:range iiopm:PredictiveModel .

iiopm:hasSensor a owl:ObjectProperty ;
    rdfs:label "has sensor" ;
    rdfs:comment "Relates a machine to its sensors." ;
    rdfs:domain iiopm:IndustrialMachine ;
    rdfs:range iiopm:Sensor .

iiopm:hasUnit a owl:ObjectProperty ;
    rdfs:label "has unit"^^xsd:string ;
    rdfs:comment "Associates a Parameter with its measurement unit."^^xsd:string ;
    rdfs:domain iiopm:Parameter ;
    rdfs:range iiopm:Unit .

iiopm:monitorsParameter a owl:ObjectProperty ;
    rdfs:label "monitors parameter"^^xsd:string ;
    rdfs:comment "Indicates that a machine monitors a given parameter."^^xsd:string,
        "Links a machine to the Parameter it monitors."^^xsd:string ;
    rdfs:domain iiopm:IndustrialMachine ;
    rdfs:range iiopm:Parameter .

iiopm:producesData a owl:ObjectProperty ;
    rdfs:label "produces data" ;
    rdfs:comment "Sensor produces time series data." ;
    rdfs:domain iiopm:Sensor ;
    rdfs:range iiopm:TimeSeries .

iiopm:recommendsMaintenance a owl:ObjectProperty ;
    rdfs:label "recommends maintenance"^^xsd:string ;
    rdfs:comment "Indicates that a forecast or anomaly recommends a maintenance action."^^xsd:string ;
    rdfs:domain iiopm:Forecast ;
    rdfs:range iiopm:MaintenanceAction .

iiopm:timestamp a owl:DatatypeProperty ;
    rdfs:label "timestamp" ;
    rdfs:comment "Timestamp of a measurement." ;
    rdfs:domain iiopm:TimeSeries ;
    rdfs:range xsd:dateTime .

iiopm:usesProtocol a owl:ObjectProperty ;
    rdfs:label "uses protocol" ;
    rdfs:comment "IoT transmission protocol." ;
    rdfs:domain iiopm:DataTransmission ;
    rdfs:range iiopm:IoTProtocol .

iiopm:value a owl:DatatypeProperty ;
    rdfs:label "value" ;
    rdfs:comment "Measured value." ;
    rdfs:domain iiopm:Parameter ;
    rdfs:range xsd:double .

iiopm:hasAnomalyEvent a owl:ObjectProperty ;
    rdfs:label "has anomaly event"^^xsd:string ;
    rdfs:comment "Connects a time series to detected anomalies."^^xsd:string ;
    rdfs:domain iiopm:TimeSeries ;
    rdfs:range iiopm:AnomalyEvent .

