LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o
LLM_API_KEY=${OPENAI_API_KEY}
RENDER_MODE=ontology_and_facts
ONTOCAST_WORKING_DIRECTORY=pipeline/full_mode/test_output
PARALLEL_WORKERS=2
PARALLEL_FACTS_RETRIES=3
PARALLEL_ONTOLOGY_RETRIES=3
MAX_VISITS_PER_NODE=3
ENABLE_ONTOLOGY_CONSOLIDATION=false

# Intentionally omitted for full bootstrap mode:
# - SKIP_ONTOLOGY_CRITIQUE
# - ONTOCAST_ONTOLOGY_DIRECTORY
